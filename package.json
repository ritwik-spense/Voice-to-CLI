{
  "name": "@ritwik-spense/voice-input",
  "displayName": "Voice Input",
  "description": "Press Ctrl+Space to dictate text into your editor via STT",
  "version": "0.1.8",
  "publisher": "spense",
  "repository": {
    "type": "git",
    "url": "https://github.com/ritwik-spense/Voice-to-CLI.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:voiceInput.toggle"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -p ./",
    "bundle": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --no-dependencies --allow-missing-repository",
    "preinstall": "node scripts/uninstall-extension.js",
    "postinstall": "node scripts/install-extension.js"
  },
  "files": [
    "scripts/install-extension.js",
    "voice-input.vsix",
    "out/**",
    "README.md"
  ],
  "contributes": {
    "commands": [
      {
        "command": "voiceInput.toggle",
        "title": "Voice Input: Toggle Recording"
      }
    ],
    "keybindings": [
      {
        "command": "voiceInput.toggle",
        "key": "ctrl+shift+space",
        "mac": "ctrl+shift+space",
        "when": "terminalFocus"
      }
    ],
    "configuration": {
      "title": "Voice Input",
      "properties": {
        "voiceInput.sttUrl": {
          "type": "string",
          "default": "http://65.0.42.25:9000/v1/audio/transcriptions",
          "description": "STT server endpoint URL"
        },
        "voiceInput.sttModel": {
          "type": "string",
          "default": "deepdml/faster-whisper-large-v3-turbo-ct2",
          "description": "STT model name"
        },
        "voiceInput.language": {
          "type": "string",
          "default": "en",
          "description": "Language code for transcription (en, hi, kn, ta, or auto)"
        },
        "voiceInput.translateToEnglish": {
          "type": "boolean",
          "default": true,
          "description": "Translate non-English speech to English before inserting"
        },
        "voiceInput.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for authentication (required). Get this from your team admin."
        },
        "voiceInput.silenceDuration": {
          "type": "number",
          "default": 1.5,
          "description": "Seconds of silence before auto-stopping recording"
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "form-data": "^4.0.0"
  }
}
